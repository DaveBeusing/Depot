<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Navigation List -->

	<Style
		x:Key="NavigationListBoxStyle"
		TargetType="ListBox">

		<Setter	Property="Background" Value="Transparent" />
		<Setter	Property="BorderThickness" Value="0" />
		<Setter Property="Foreground" Value="{DynamicResource NavigationForegroundBrush}" />

	</Style>

	<!-- Navigation Item -->
	<Style
		x:Key="NavigationListBoxItemStyle"
		TargetType="ListBoxItem">		
		<Setter	Property="Padding" Value="12" />
		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ListBoxItem">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="4"/>
							<ColumnDefinition Width="8"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<!-- Accent -->
						<Border
							x:Name="Accent"
							Grid.Column="0"
							Margin="0,2,0,2"
							Background="{DynamicResource NavigationAccentBrush}"
							CornerRadius="0,2,2,0"
							Visibility="Collapsed"/>

						<!-- Content -->
						<Border
							x:Name="Background"
							Grid.Column="2"
							Background="Transparent"
							CornerRadius="6"
							Padding="{TemplateBinding Padding}">
							<ContentPresenter VerticalAlignment="Center"/>
						</Border>
					</Grid>

					<ControlTemplate.Triggers>
						<!-- Hover -->
						<Trigger Property="IsMouseOver" Value="True">
							<Setter TargetName="Background" Property="Background" Value="{DynamicResource NavigationHoverBrush}" />
						</Trigger>

						<!-- Selected -->
						<Trigger Property="IsSelected" Value="True">
							<Setter
								TargetName="Accent"
								Property="Visibility"
								Value="Visible" />
							<Setter
								TargetName="Background"
								Property="Background"
								Value="{DynamicResource NavigationSelectedBackgroundBrush}" />
						</Trigger>
					</ControlTemplate.Triggers>

				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- Navigation Item Template -->
	<DataTemplate x:Key="NavigationItemTemplate">
		<StackPanel Orientation="Horizontal">
			<TextBlock
				Width="24"
				Text="{Binding Icon}"
				Style="{DynamicResource NavigationTextStyle}" />

			<TextBlock
				Text="{Binding Name}"
				Style="{DynamicResource NavigationTextStyle}" />

		</StackPanel>
	</DataTemplate>

</ResourceDictionary>