<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<Style TargetType="{x:Type controls:PageHeader}">
		<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type controls:PageHeader}">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<StackPanel VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
							<ContentPresenter
								Content="{TemplateBinding Title}"
								ContentTemplate="{TemplateBinding TitleTemplate}"
								TextElement.FontSize="22"
								TextElement.FontWeight="SemiBold"
								TextElement.Foreground="{TemplateBinding Foreground}" />

							<ContentPresenter
								x:Name="SubtitlePresenter"
								Margin="0,4,0,0"
								Content="{TemplateBinding Subtitle}"
								ContentTemplate="{TemplateBinding SubtitleTemplate}"
								TextElement.FontSize="13"
								TextElement.Foreground="{DynamicResource SecondaryTextBrush}" />
						</StackPanel>

						<ContentPresenter
							x:Name="ActionsPresenter"
							Grid.Column="1"
							Margin="24,0,0,0"
							VerticalAlignment="Center"
							Content="{TemplateBinding Actions}"
							ContentTemplate="{TemplateBinding ActionsTemplate}" />
					</Grid>
					<ControlTemplate.Triggers>
						<Trigger Property="Subtitle" Value="{x:Null}">
							<Setter TargetName="SubtitlePresenter" Property="Visibility" Value="Collapsed" />
						</Trigger>
						<Trigger Property="Actions" Value="{x:Null}">
							<Setter TargetName="ActionsPresenter" Property="Visibility" Value="Collapsed" />
						</Trigger>
						<Trigger Property="IsEnabled" Value="False">
							<Setter Property="Opacity" Value="0.6" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
