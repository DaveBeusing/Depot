<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<DataTemplate x:Key="EmptyStateTitleTemplate">
		<TextBlock
			Text="{Binding}"
			TextAlignment="Center"
			TextWrapping="Wrap" />
	</DataTemplate>

	<DataTemplate x:Key="EmptyStateDescriptionTemplate">
		<TextBlock
			Text="{Binding}"
			TextAlignment="Center"
			TextWrapping="Wrap" />
	</DataTemplate>

	<Style TargetType="{x:Type controls:EmptyState}">
		<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="TitleTemplate" Value="{StaticResource EmptyStateTitleTemplate}" />
		<Setter Property="DescriptionTemplate" Value="{StaticResource EmptyStateDescriptionTemplate}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type controls:EmptyState}">
					<StackPanel
						MaxWidth="480"
						Margin="24"
						HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
						VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
						<Border
							Width="48"
							Height="48"
							HorizontalAlignment="Center"
							Background="{DynamicResource SurfaceAltBrush}"
							CornerRadius="24">
							<Path
								Width="20"
								Height="18"
								Data="M 2,2 L 18,2 L 18,16 L 2,16 Z M 2,6 L 7,6 L 8.5,9 L 11.5,9 L 13,6 L 18,6"
								Stroke="{DynamicResource SecondaryTextBrush}"
								StrokeLineJoin="Round"
								StrokeThickness="1.5" />
						</Border>

						<ContentPresenter
							Margin="0,16,0,0"
							HorizontalAlignment="Center"
							Content="{TemplateBinding Title}"
							ContentTemplate="{TemplateBinding TitleTemplate}"
							TextElement.FontSize="18"
							TextElement.FontWeight="SemiBold"
							TextElement.Foreground="{TemplateBinding Foreground}" />

						<ContentPresenter
							x:Name="DescriptionPresenter"
							Margin="0,8,0,0"
							HorizontalAlignment="Center"
							Content="{TemplateBinding Description}"
							ContentTemplate="{TemplateBinding DescriptionTemplate}"
							TextElement.FontSize="13"
							TextElement.Foreground="{DynamicResource SecondaryTextBrush}" />

						<ContentPresenter
							x:Name="ActionPresenter"
							Margin="0,16,0,0"
							HorizontalAlignment="Center"
							Content="{TemplateBinding Action}"
							ContentTemplate="{TemplateBinding ActionTemplate}" />
					</StackPanel>
					<ControlTemplate.Triggers>
						<Trigger Property="Description" Value="{x:Null}">
							<Setter TargetName="DescriptionPresenter" Property="Visibility" Value="Collapsed" />
						</Trigger>
						<Trigger Property="Action" Value="{x:Null}">
							<Setter TargetName="ActionPresenter" Property="Visibility" Value="Collapsed" />
						</Trigger>
						<Trigger Property="IsEnabled" Value="False">
							<Setter Property="Opacity" Value="0.6" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
