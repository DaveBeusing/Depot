<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Base -->
	<SolidColorBrush x:Key="BackgroundBrush"	Color="#F7F8FA" />
	<SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
	<SolidColorBrush x:Key="SurfaceAltBrush"	Color="#F9FAFB" />

	<!-- Primary -->
	<SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
	<SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFF" />
	<SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8" />
	<SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1E40AF" />
	<SolidColorBrush x:Key="HoverBrush" Color="#0D2563EB" />
	<SolidColorBrush x:Key="CardBorderBrush" Color="#EEF2F7" />

	<!-- Text -->
	<SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827" />
	<SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B7280" />

	<!-- Borders -->
	<SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB" />

	<!-- Navigation -->
	<SolidColorBrush x:Key="NavigationBackgroundBrush" Color="#1F2937" />
	<SolidColorBrush x:Key="NavigationForegroundBrush" Color="#E5E7EB" />
	<SolidColorBrush x:Key="NavigationHoverBrush" Color="#374151" />
	<SolidColorBrush x:Key="NavigationSelectedBrush" Color="#2563EB" />

	<!-- Navigation Selection -->
	<SolidColorBrush x:Key="NavigationSelectedBackgroundBrush" Color="#1A2563EB" />
	<SolidColorBrush x:Key="NavigationAccentBrush" Color="#2563EB" />

	<!-- Sidebar -->
	<SolidColorBrush x:Key="NavigationBorderBrush" Color="#2E3948" />

	<!-- Status -->
	<SolidColorBrush x:Key="SuccessBrush" Color="#DCFCE7" />
	<SolidColorBrush x:Key="SuccessForegroundBrush" Color="#166534" />
	<SolidColorBrush x:Key="WarningBrush" Color="#FEF3C7" />
	<SolidColorBrush x:Key="WarningForegroundBrush" Color="#92400E" />
	<SolidColorBrush x:Key="ErrorBrush" Color="#FEE2E2" />
	<SolidColorBrush x:Key="ErrorForegroundBrush" Color="#991B1B" />

</ResourceDictionary>
