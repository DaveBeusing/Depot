<Window
	x:Class="Depot.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewModels="clr-namespace:Depot.ViewModels"
	xmlns:views="clr-namespace:Depot.Views"
	mc:Ignorable="d"
	Title="Depot - Local Inventory Management"
	Width="1600"
	Height="950"
	MinWidth="1200"
	MinHeight="700">

	<Window.Resources>

		<DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
			<views:DashboardView />
		</DataTemplate>

		<DataTemplate DataType="{x:Type viewModels:InventoryViewModel}">
			<views:InventoryView />
		</DataTemplate>

		<DataTemplate DataType="{x:Type viewModels:ItemsViewModel}">
			<views:ItemsView />
		</DataTemplate>

		<DataTemplate DataType="{x:Type viewModels:MovementsViewModel}">
			<views:MovementsView />
		</DataTemplate>

		<DataTemplate DataType="{x:Type viewModels:ImportViewModel}">
			<views:ImportView />
		</DataTemplate>

	</Window.Resources>

	<Grid>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="240" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Border
			Grid.Column="0"
			Background="{StaticResource SidebarBrush}">

			<DockPanel>

				<TextBlock
					DockPanel.Dock="Top"
					Margin="24"
					Text="📦 Depot"
					FontSize="28"
					FontWeight="SemiBold"
					Foreground="{StaticResource SidebarForegroundBrush}" />

				<ListBox
					ItemsSource="{Binding NavigationItems}"
					SelectedItem="{Binding SelectedNavigationItem}"
					Background="Transparent"
					BorderThickness="0"
					Foreground="{StaticResource SidebarForegroundBrush}">

					<ListBox.ItemContainerStyle>

						<Style TargetType="ListBoxItem">

							<Setter Property="Margin"
									Value="8,2" />

							<Setter Property="Padding"
									Value="8" />

							<Setter Property="HorizontalContentAlignment"
									Value="Stretch" />

							<Setter Property="Template">

								<Setter.Value>

									<ControlTemplate TargetType="ListBoxItem">

										<Border
											x:Name="Border"
											Background="Transparent"
											CornerRadius="6"
											Padding="8">

											<ContentPresenter />

										</Border>

										<ControlTemplate.Triggers>

											<Trigger Property="IsMouseOver"
													Value="True">

												<Setter TargetName="Border"
														Property="Background"
														Value="#374151" />

											</Trigger>

											<Trigger Property="IsSelected"
													Value="True">

												<Setter TargetName="Border"
														Property="Background"
														Value="{StaticResource AccentBrush}" />

											</Trigger>

										</ControlTemplate.Triggers>

									</ControlTemplate>

								</Setter.Value>

							</Setter>

						</Style>

					</ListBox.ItemContainerStyle>

					<ListBox.ItemTemplate>

						<DataTemplate>

							<TextBlock
								FontSize="14"
								FontWeight="SemiBold"
								Text="{Binding Name}" />

						</DataTemplate>

					</ListBox.ItemTemplate>

				</ListBox>

			</DockPanel>

		</Border>

		<Border
			Grid.Column="1"
			Margin="16"
			Padding="16"
			Background="White"
			BorderBrush="#E5E7EB"
			BorderThickness="1">

			<ContentControl
				Content="{Binding CurrentViewModel}" />

		</Border>

	</Grid>

</Window>