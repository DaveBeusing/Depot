<Window
	x:Class="Depot.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	Title="Depot"
	Width="1400"
	Height="900"
	MinWidth="1200"
	MinHeight="700">

	<Grid>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="220" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Border
			Grid.Column="0"
			Background="#F4F4F4">

			<DockPanel>

				<TextBlock
					DockPanel.Dock="Top"
					Margin="16"
					Text="Depot"
					FontSize="24"
					FontWeight="SemiBold" />

				<ListBox
					ItemsSource="{Binding NavigationItems}"
					SelectedItem="{Binding SelectedNavigationItem}"
					BorderThickness="0"
					Background="Transparent">

					<ListBox.ItemTemplate>
						<DataTemplate>
							<TextBlock
								Margin="12"
								Text="{Binding Name}" />
						</DataTemplate>
					</ListBox.ItemTemplate>

				</ListBox>

			</DockPanel>

		</Border>

		<Grid
			Grid.Column="1"
			Margin="16">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="16" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<TextBlock
				Grid.Row="0"
				Text="Items"
				FontSize="22"
				FontWeight="SemiBold" />

			<DataGrid
				Grid.Row="2"
				ItemsSource="{Binding Items}"
				AutoGenerateColumns="False"
				IsReadOnly="True"
				CanUserAddRows="False"
				CanUserDeleteRows="False">

				<DataGrid.Columns>

					<DataGridTextColumn
						Header="Part Number"
						Binding="{Binding PartNumber}"
						Width="180" />

					<DataGridTextColumn
						Header="Description"
						Binding="{Binding Description}"
						Width="*" />

					<DataGridTextColumn
						Header="Manufacturer"
						Binding="{Binding Manufacturer}"
						Width="180" />

					<DataGridTextColumn
						Header="Category"
						Binding="{Binding Category}"
						Width="180" />

				</DataGrid.Columns>

			</DataGrid>

		</Grid>

	</Grid>

</Window>