<Window
	x:Class="Depot.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewModels="clr-namespace:Depot.ViewModels"
	xmlns:administrationViewModels="clr-namespace:Depot.ViewModels.Administration"
	xmlns:sharedViewModels="clr-namespace:Depot.ViewModels.Shared"
	xmlns:views="clr-namespace:Depot.Views"
	xmlns:administrationViews="clr-namespace:Depot.Views.Administration"
	xmlns:sharedViews="clr-namespace:Depot.Views.Shared"
	xmlns:masterDataViewModels="clr-namespace:Depot.ViewModels.MasterData"
	xmlns:masterDataViews="clr-namespace:Depot.Views.MasterData"
	xmlns:purposeViewModels="clr-namespace:Depot.ViewModels.Purposes"
	xmlns:purposeViews="clr-namespace:Depot.Views.Purposes"
	mc:Ignorable="d"
	Title="Depot"
	Width="1600"
	Height="950"
	MinWidth="1200"
	MinHeight="700">

	<Window.Resources>

		<ResourceDictionary>
			
			<DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
				<views:DashboardView />
			</DataTemplate>

			<DataTemplate DataType="{x:Type viewModels:InventoryViewModel}">
				<views:InventoryView />
			</DataTemplate>

			<DataTemplate DataType="{x:Type viewModels:ItemsViewModel}">
				<views:ItemsView />
			</DataTemplate>

			<DataTemplate DataType="{x:Type viewModels:MovementsViewModel}">
				<views:MovementsView />
			</DataTemplate>

			<DataTemplate DataType="{x:Type viewModels:ImportViewModel}">
				<views:ImportView />
			</DataTemplate>

			<DataTemplate DataType="{x:Type administrationViewModels:AdministrationViewModel}">
				<administrationViews:AdministrationView />
			</DataTemplate>

			<DataTemplate DataType="{x:Type sharedViewModels:PlaceholderViewModel}">
				<sharedViews:PlaceholderView />
			</DataTemplate>

			<DataTemplate DataType="{x:Type masterDataViewModels:MasterDataViewModel}">
				<masterDataViews:MasterDataView />
			</DataTemplate>

			<DataTemplate DataType="{x:Type purposeViewModels:PurposeViewModel}">
				<purposeViews:PurposesView />
			</DataTemplate>

		</ResourceDictionary>

	</Window.Resources>

	<Grid>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="240" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Border
			Grid.Column="0"
			Background="{StaticResource NavigationBackgroundBrush}">

			<DockPanel>

				<TextBlock
					DockPanel.Dock="Top"
					Margin="24"
					Text="📦 Depot"
					FontSize="24"
					FontWeight="SemiBold"
					Foreground="{StaticResource NavigationForegroundBrush}" />

				<ListBox
					ItemsSource="{Binding NavigationItems}"
					SelectedItem="{Binding SelectedNavigationItem}"
					Background="Transparent"
					BorderThickness="0"
					Foreground="{StaticResource NavigationForegroundBrush}">

					<ListBox.ItemContainerStyle>

						<Style TargetType="ListBoxItem">

							<Setter Property="Margin" Value="8,2" />
							<Setter Property="Padding" Value="8" />
							<Setter Property="HorizontalContentAlignment" Value="Stretch" />

							<Setter Property="Template">

								<Setter.Value>

									<ControlTemplate TargetType="ListBoxItem">

										<Border
											x:Name="Border"
											Background="Transparent"
											CornerRadius="6"
											Padding="8">

											<ContentPresenter />

										</Border>

										<ControlTemplate.Triggers>

											<Trigger Property="IsMouseOver" Value="True">

												<Setter
													TargetName="Border"
													Property="Background"
													Value="{StaticResource NavigationHoverBrush}" />

											</Trigger>

											<Trigger Property="IsSelected" Value="True">

												<Setter
													TargetName="Border"
													Property="Background"
													Value="{StaticResource NavigationSelectedBrush}" />

											</Trigger>

										</ControlTemplate.Triggers>

									</ControlTemplate>

								</Setter.Value>

							</Setter>

							<Style.Triggers>

								<DataTrigger
									Binding="{Binding Section}"
									Value="{x:Static viewModels:ShellSection.Administration}">

									<Setter Property="Margin" Value="8,24,8,2" />

								</DataTrigger>

							</Style.Triggers>

						</Style>

					</ListBox.ItemContainerStyle>

					<ListBox.ItemTemplate>

						<DataTemplate>

							<StackPanel Orientation="Horizontal">

								<TextBlock
									Width="24"
									Text="{Binding Icon}" />

								<TextBlock
									FontSize="14"
									FontWeight="SemiBold"
									Text="{Binding Name}" />

							</StackPanel>

						</DataTemplate>

					</ListBox.ItemTemplate>

				</ListBox>

			</DockPanel>

		</Border>

		<Border
			Grid.Column="1"
			Margin="16"
			Padding="16"
			Background="{StaticResource SurfaceBrush}"
			BorderBrush="{StaticResource BorderBrush}"
			BorderThickness="1">

			<ContentControl
				Content="{Binding CurrentViewModel}" />

		</Border>

	</Grid>

</Window>