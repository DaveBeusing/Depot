<Window
	x:Class="Depot.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewModels="clr-namespace:Depot.ViewModels"
	xmlns:views="clr-namespace:Depot.Views"
	mc:Ignorable="d"
	Title="Depot"
	Width="1400"
	Height="900"
	MinWidth="1200"
	MinHeight="700">

	<Window.Resources>

		<DataTemplate DataType="{x:Type viewModels:InventoryViewModel}">
			<views:InventoryView />
		</DataTemplate>
		
		<DataTemplate DataType="{x:Type viewModels:ItemsViewModel}">
			<views:ItemsView />
		</DataTemplate>

	</Window.Resources>

	<Grid>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="220" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Border
			Grid.Column="0"
			Background="#F4F4F4">

			<DockPanel>

				<TextBlock
					DockPanel.Dock="Top"
					Margin="16"
					Text="Depot"
					FontSize="24"
					FontWeight="SemiBold" />

				<ListBox
					ItemsSource="{Binding NavigationItems}"
					SelectedItem="{Binding SelectedNavigationItem}"
					BorderThickness="0"
					Background="Transparent">

					<ListBox.ItemTemplate>
						<DataTemplate>
							<TextBlock
								Margin="12"
								Text="{Binding Name}" />
						</DataTemplate>
					</ListBox.ItemTemplate>

				</ListBox>

			</DockPanel>

		</Border>

		<ContentControl
			Grid.Column="1"
			Margin="16"
			Content="{Binding CurrentViewModel}" />

	</Grid>

</Window>