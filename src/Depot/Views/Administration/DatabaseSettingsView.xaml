<UserControl
	x:Class="Depot.Views.Administration.DatabaseSettingsView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel MaxWidth="760" HorizontalAlignment="Left">
			<TextBlock
				Text="Database connection"
				Style="{StaticResource SectionTitleStyle}" />
			<TextBlock
				Margin="0,6,0,20"
				Foreground="{StaticResource SecondaryTextBrush}"
				Text="Choose the database target and securely store its connection settings."
				TextWrapping="Wrap" />

			<controls:ConnectionStatusIndicator
				Margin="0,0,0,20"
				State="{Binding ConnectionStatus.State}"
				Status="{Binding ConnectionStatus.Status}"
				Detail="{Binding ConnectionStatus.Detail}" />

			<StackPanel Margin="0,0,0,16" Orientation="Horizontal">
				<RadioButton
					Content="Local database"
					GroupName="DatabaseProvider"
					IsChecked="{Binding UseLocalDatabase}"
					Style="{StaticResource OptionRadioButtonStyle}" />
				<RadioButton
					Margin="16,0,0,0"
					Content="SQL Server"
					GroupName="DatabaseProvider"
					IsChecked="{Binding UseSqlServer}"
					Style="{StaticResource OptionRadioButtonStyle}" />
				<RadioButton
					Margin="16,0,0,0"
					Content="MySQL / MariaDB"
					GroupName="DatabaseProvider"
					IsChecked="{Binding UseMySql}"
					Style="{StaticResource OptionRadioButtonStyle}" />
			</StackPanel>

			<Border
				Padding="16"
				Background="{StaticResource SurfaceAltBrush}"
				BorderBrush="{StaticResource BorderBrush}"
				BorderThickness="1"
				CornerRadius="8">
				<StackPanel>
					<TextBlock Text="Local SQLite database" Style="{StaticResource CardTitleStyle}" />
					<TextBlock
						Margin="0,12,0,4"
						Text="Database file"
						Style="{StaticResource FormLabelStyle}" />
					<TextBox
						Style="{StaticResource AppTextBoxStyle}"
						Text="{Binding LocalDatabasePath}" />
					<TextBlock
						Margin="0,6,0,0"
						Style="{StaticResource HintStyle}"
						Text="Used on first installation and as the current fallback database." />
				</StackPanel>
			</Border>

			<Border
				Margin="0,16,0,0"
				Padding="16"
				Background="{StaticResource SurfaceAltBrush}"
				BorderBrush="{StaticResource BorderBrush}"
				BorderThickness="1"
				CornerRadius="8"
				IsEnabled="{Binding IsMySqlSelected}">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="16" />
						<ColumnDefinition Width="180" />
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="4" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="4" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="4" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<TextBlock Grid.ColumnSpan="3" Text="MySQL / MariaDB connection" Style="{StaticResource CardTitleStyle}" />
					<TextBlock Grid.Row="2" Text="Server" Style="{StaticResource FormLabelStyle}" />
					<TextBlock Grid.Row="2" Grid.Column="2" Text="Port" Style="{StaticResource FormLabelStyle}" />
					<TextBox Grid.Row="4" Style="{StaticResource AppTextBoxStyle}" Text="{Binding MySqlHost}" />
					<TextBox Grid.Row="4" Grid.Column="2" Style="{StaticResource AppTextBoxStyle}" Text="{Binding MySqlPort}" />

					<TextBlock Grid.Row="6" Grid.ColumnSpan="3" Text="Database" Style="{StaticResource FormLabelStyle}" />
					<TextBox Grid.Row="8" Grid.ColumnSpan="3" Style="{StaticResource AppTextBoxStyle}" Text="{Binding MySqlDatabase}" />

					<TextBlock Grid.Row="10" Text="User name" Style="{StaticResource FormLabelStyle}" />
					<TextBlock Grid.Row="10" Grid.Column="2" Text="Password" Style="{StaticResource FormLabelStyle}" />
					<TextBox Grid.Row="12" Style="{StaticResource AppTextBoxStyle}" Text="{Binding MySqlUserName}" />
					<controls:PasswordInput
						Grid.Row="12"
						Grid.Column="2"
						PasswordValue="{Binding MySqlPassword, UpdateSourceTrigger=PropertyChanged}" />

					<CheckBox
						Grid.Row="14"
						Grid.ColumnSpan="3"
						Content="Require TLS encryption"
						IsChecked="{Binding UseMySqlTls}"
						Style="{StaticResource AppCheckBoxStyle}" />
				</Grid>
			</Border>

			<Border
				Margin="0,16,0,0"
				Padding="16"
				Background="{StaticResource SurfaceAltBrush}"
				BorderBrush="{StaticResource BorderBrush}"
				BorderThickness="1"
				CornerRadius="8"
				IsEnabled="{Binding IsSqlServerSelected}">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="16" />
						<ColumnDefinition Width="180" />
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="4" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="4" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="4" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<TextBlock Grid.ColumnSpan="3" Text="SQL Server connection" Style="{StaticResource CardTitleStyle}" />
					<TextBlock Grid.Row="2" Text="Server" Style="{StaticResource FormLabelStyle}" />
					<TextBlock Grid.Row="2" Grid.Column="2" Text="Port" Style="{StaticResource FormLabelStyle}" />
					<TextBox Grid.Row="4" Style="{StaticResource AppTextBoxStyle}" Text="{Binding SqlServerHost}" />
					<TextBox Grid.Row="4" Grid.Column="2" Style="{StaticResource AppTextBoxStyle}" Text="{Binding SqlServerPort}" />

					<TextBlock Grid.Row="6" Grid.ColumnSpan="3" Text="Database" Style="{StaticResource FormLabelStyle}" />
					<TextBox Grid.Row="8" Grid.ColumnSpan="3" Style="{StaticResource AppTextBoxStyle}" Text="{Binding SqlServerDatabase}" />

					<TextBlock Grid.Row="10" Text="User name" Style="{StaticResource FormLabelStyle}" />
					<TextBlock Grid.Row="10" Grid.Column="2" Text="Password" Style="{StaticResource FormLabelStyle}" />
					<TextBox Grid.Row="12" Style="{StaticResource AppTextBoxStyle}" Text="{Binding SqlServerUserName}" />
					<controls:PasswordInput
						Grid.Row="12"
						Grid.Column="2"
						PasswordValue="{Binding SqlServerPassword, UpdateSourceTrigger=PropertyChanged}" />

					<StackPanel Grid.Row="14" Grid.ColumnSpan="3" Orientation="Horizontal">
						<CheckBox
							Content="Encrypt connection"
							IsChecked="{Binding EncryptSqlServerConnection}"
							Style="{StaticResource AppCheckBoxStyle}" />
						<CheckBox
							Margin="24,0,0,0"
							Content="Trust server certificate"
							IsChecked="{Binding TrustSqlServerCertificate}"
							Style="{StaticResource AppCheckBoxStyle}" />
					</StackPanel>
				</Grid>
			</Border>

			<Border
				Margin="0,16,0,0"
				Padding="12"
				Background="{StaticResource WarningBrush}"
				CornerRadius="6">
				<TextBlock
					Foreground="{StaticResource WarningForegroundBrush}"
					Text="Provider changes are verified before saving and become active after restarting Depot. Server credentials remain encrypted in depot.settings."
					TextWrapping="Wrap" />
			</Border>

			<Grid Margin="0,16,0,0">
				<Border
					Padding="12"
					Background="{StaticResource SuccessBrush}"
					CornerRadius="6"
					Visibility="{Binding HasSuccessMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
					<TextBlock Foreground="{StaticResource SuccessForegroundBrush}" Text="{Binding Message}" TextWrapping="Wrap" />
				</Border>
				<Border
					Padding="12"
					Background="{StaticResource ErrorBrush}"
					CornerRadius="6"
					Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
					<TextBlock Foreground="{StaticResource ErrorForegroundBrush}" Text="{Binding Message}" TextWrapping="Wrap" />
				</Border>
			</Grid>

			<StackPanel Margin="0,20,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
				<Button
					Command="{Binding TestConnectionCommand}"
					Content="Test connection"
					Style="{StaticResource SecondaryButtonStyle}" />
				<Button
					Margin="12,0,0,0"
					Command="{Binding SaveCommand}"
					Content="Save settings"
					Style="{StaticResource PrimaryButtonStyle}" />
			</StackPanel>

			<Separator Margin="0,32,0,28" />

			<TextBlock Text="Database management" Style="{StaticResource SectionTitleStyle}" />
			<TextBlock
				Margin="0,6,0,20"
				Foreground="{StaticResource SecondaryTextBrush}"
				Text="Monitor, protect and maintain the active Depot database. Credentials are never displayed."
				TextWrapping="Wrap" />

			<controls:OperationStatus
				ErrorText="{Binding OperationError}"
				HasError="{Binding HasOperationError}"
				IsBusy="{Binding IsBusy}"
				StatusText="{Binding StatusText}" />
			<ProgressBar
				Height="4"
				Margin="0,0,0,16"
				Maximum="100"
				Value="{Binding OperationProgress, Mode=OneWay}"
				Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

			<controls:Card>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="24" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<TextBlock Text="Provider" Style="{StaticResource FormLabelStyle}" />
					<TextBlock Grid.Column="2" Text="Schema version" Style="{StaticResource FormLabelStyle}" />
					<TextBlock Grid.Row="2" Text="{Binding ProviderDisplay}" Style="{StaticResource CardTitleStyle}" />
					<TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding SchemaVersionDisplay}" Style="{StaticResource CardTitleStyle}" />
					<TextBlock Grid.Row="4" Text="Active connection" Style="{StaticResource FormLabelStyle}" />
					<TextBlock Grid.Row="4" Grid.Column="2" Text="Database size" Style="{StaticResource FormLabelStyle}" />
					<TextBlock Grid.Row="6" Text="{Binding ConnectionDisplay}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ConnectionDisplay}" />
					<TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding DatabaseSizeDisplay}" />
					<TextBlock Grid.Row="8" Text="Last successful backup" Style="{StaticResource FormLabelStyle}" />
					<TextBlock Grid.Row="8" Grid.Column="2" Text="Next scheduled backup" Style="{StaticResource FormLabelStyle}" />
					<TextBlock Grid.Row="10" Text="{Binding LastBackupDisplay}" />
					<TextBlock Grid.Row="10" Grid.Column="2" Text="{Binding NextBackupDisplay}" />
				</Grid>
			</controls:Card>

			<controls:Card Margin="0,16,0,0">
				<StackPanel>
					<TextBlock Text="Automatic backups" Style="{StaticResource CardTitleStyle}" />
					<CheckBox
						Margin="0,16,0,0"
						Content="Create backups automatically"
						IsChecked="{Binding AutomaticBackupsEnabled}"
						Style="{StaticResource AppCheckBoxStyle}" />
					<Grid Margin="0,16,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="16" />
							<ColumnDefinition Width="160" />
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="4" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<TextBlock Text="Backup directory" Style="{StaticResource FormLabelStyle}" />
						<TextBlock Grid.Column="2" Text="Interval in days" Style="{StaticResource FormLabelStyle}" />
						<TextBox Grid.Row="2" Style="{StaticResource AppTextBoxStyle}" Text="{Binding BackupDirectory}" />
						<TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource AppTextBoxStyle}" Text="{Binding BackupIntervalDays}" />
					</Grid>
					<TextBlock
						Margin="0,8,0,0"
						Style="{StaticResource HintStyle}"
						Text="The encrypted depot.settings file stores the schedule. Due backups resume automatically after a restart." />
					<Button
						Margin="0,16,0,0"
						HorizontalAlignment="Right"
						Command="{Binding SaveCommand}"
						Content="Save backup schedule"
						Style="{StaticResource PrimaryButtonStyle}" />
				</StackPanel>
			</controls:Card>

			<controls:Card Margin="0,16,0,0">
				<StackPanel>
					<TextBlock Text="Maintenance actions" Style="{StaticResource CardTitleStyle}" />
					<WrapPanel Margin="0,16,0,0">
						<Button Command="{Binding CreateBackupCommand}" Content="Create backup" Style="{StaticResource PrimaryButtonStyle}" />
						<Button Margin="8,0,0,0" Command="{Binding RestoreBackupCommand}" Content="Restore backup" Style="{StaticResource SecondaryButtonStyle}" />
						<Button Margin="8,0,0,0" Command="{Binding ValidateBackupCommand}" Content="Validate backup" Style="{StaticResource SecondaryButtonStyle}" />
						<Button Margin="8,0,0,0" Command="{Binding CheckIntegrityCommand}" Content="Check integrity" Style="{StaticResource SecondaryButtonStyle}" />
						<Button Margin="8,0,0,0" Command="{Binding CompactCommand}" Content="Compact SQLite" Style="{StaticResource SecondaryButtonStyle}" />
						<Button Margin="8,0,0,0" Command="{Binding RefreshCommand}" Content="Refresh" Style="{StaticResource SecondaryButtonStyle}" />
					</WrapPanel>
					<TextBlock
						Margin="0,12,0,0"
						Foreground="{StaticResource SecondaryTextBrush}"
						Text="Restore validates the selected backup and creates a safety backup before replacing any records. Compact is available only for SQLite."
						TextWrapping="Wrap" />
				</StackPanel>
			</controls:Card>

			<TextBlock Margin="0,24,0,12" Text="Available backups" Style="{StaticResource SectionTitleStyle}" />
			<DataGrid
				MinHeight="220"
				AutoGenerateColumns="False"
				ItemsSource="{Binding Backups}"
				SelectedItem="{Binding SelectedBackup}"
				Style="{StaticResource AppDataGridStyle}">
				<DataGrid.Columns>
					<DataGridTextColumn Width="145" Binding="{Binding CreatedDisplay}" Header="Created" />
					<DataGridTextColumn Width="90" Binding="{Binding SizeDisplay}" Header="Size" />
					<DataGridTextColumn Width="90" Binding="{Binding Provider}" Header="Provider" />
					<DataGridCheckBoxColumn Width="70" Binding="{Binding IsValid}" Header="Valid" IsReadOnly="True" />
					<DataGridTextColumn Width="*" Binding="{Binding FilePath}" Header="Path" />
				</DataGrid.Columns>
			</DataGrid>
			<TextBlock
				Margin="0,8,0,24"
				Foreground="{StaticResource SecondaryTextBrush}"
				Text="{Binding SelectedBackup.ValidationMessage}"
				TextWrapping="Wrap" />
		</StackPanel>
	</ScrollViewer>
</UserControl>
