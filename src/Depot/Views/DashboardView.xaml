<UserControl
	x:Class="Depot.Views.DashboardView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<Grid>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="24" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<controls:PageHeader
			Grid.Row="0"
			Title="Dashboard" />

		<controls:OperationStatus
			Grid.Row="1"
			IsBusy="{Binding IsBusy}"
			HasError="{Binding HasOperationError}"
			StatusText="{Binding StatusText}"
			ErrorText="{Binding OperationError}" />

		<Grid Grid.Row="2">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<controls:MetricCard
				Grid.Column="0"
				Icon="M 5,3 L 15,3 L 17,5 L 17,19 L 3,19 L 3,5 Z M 7,3 L 7,1 L 13,1 L 13,3 M 7,8 L 13,8 M 7,12 L 13,12 M 7,16 L 11,16"
				SupportingText="Catalog entries"
				Title="Total Items"
				Value="{Binding TotalItems}" />

			<controls:MetricCard
				Grid.Column="2"
				Icon="M 2,6 L 10,2 L 18,6 L 10,10 Z M 2,6 L 2,14 L 10,18 L 10,10 M 18,6 L 18,14 L 10,18"
				SupportingText="Units currently on hand"
				Title="Total Stock"
				Value="{Binding TotalStockQuantity}" />

			<controls:MetricCard
				Grid.Column="4"
				Icon="M 18,10 A 8,8 0 1 1 2,10 A 8,8 0 1 1 18,10 M 12.5,6.5 C 11.8,5.8 8.5,5.5 8,7 C 7.4,8.8 12.8,8.5 12,11 C 11.5,12.5 8.2,12.2 7.5,11.5 M 10,4.5 L 10,15.5"
				SupportingText="Current inventory valuation"
				Title="Inventory Value"
				Value="{Binding TotalInventoryValue}"
				ValueStringFormat="{}{0:C2}" />

			<controls:MetricCard
				Grid.Column="6"
				Icon="M 3,6 L 15,6 M 12,3 L 15,6 L 12,9 M 17,14 L 5,14 M 8,11 L 5,14 L 8,17"
				SupportingText="Recorded stock transactions"
				Title="Movements"
				Value="{Binding TotalMovements}" />

		</Grid>

		<controls:Card Grid.Row="4">
			<controls:Card.Header>
				<TextBlock
					Text="Recent Movements"
					Style="{StaticResource SectionTitleStyle}" />
			</controls:Card.Header>

			<DataGrid
				Style="{StaticResource AppDataGridStyle}"
				ItemsSource="{Binding RecentMovements}">

					<DataGrid.Columns>

						<DataGridTextColumn
							Header="Date"
							Binding="{Binding TimestampLocal}"
							Width="180" />

						<DataGridTextColumn
							Header="Part Number"
							Binding="{Binding PartNumber}"
							Width="180" />

						<DataGridTextColumn
							Header="Description"
							Binding="{Binding Description}"
							Width="*" />

						<DataGridTextColumn
							Header="Purpose"
							Binding="{Binding PurposeName}"
							Width="140" />

						<DataGridTextColumn
							Header="Warehouse"
							Binding="{Binding WarehouseName}"
							Width="140" />

						<DataGridTextColumn
							Header="Storage Location"
							Binding="{Binding LocationName}"
							Width="140" />

						<DataGridTextColumn
							Header="Type"
							Binding="{Binding MovementType}"
							Width="120" />

						<DataGridTextColumn
							Header="Quantity"
							Binding="{Binding Quantity}"
							Width="100" />

					</DataGrid.Columns>

			</DataGrid>
		</controls:Card>

	</Grid>

</UserControl>
