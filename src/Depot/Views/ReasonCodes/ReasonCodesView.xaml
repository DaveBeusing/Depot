<UserControl
	x:Class="Depot.Views.ReasonCodes.ReasonCodesView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="16" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<controls:PageHeader
			Title="Reason Codes"
			Subtitle="Maintain the business reasons used to classify stock movements.">
			<controls:PageHeader.Actions>
				<controls:OperationStatus ErrorText="{Binding OperationError}" HasError="{Binding HasOperationError}" IsBusy="{Binding IsBusy}" StatusText="{Binding StatusText}" />
			</controls:PageHeader.Actions>
		</controls:PageHeader>

		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="8" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<controls:SearchBox Placeholder="Search reason codes" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
				<DataGrid Grid.Row="2" ItemsSource="{Binding ReasonCodes}" SelectedItem="{Binding SelectedReasonCode}" Style="{StaticResource AppDataGridStyle}">
					<DataGrid.Columns>
						<DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220" />
						<DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
						<DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=OneWay}" Width="80" />
					</DataGrid.Columns>
				</DataGrid>
			</Grid>

			<controls:Card Grid.Column="2">
				<StackPanel>
					<TextBlock Text="{Binding EditorTitle}" Style="{StaticResource SectionTitleStyle}" />
					<TextBlock Margin="0,16,0,4" Text="Name" Style="{StaticResource FormLabelStyle}" />
					<TextBox Style="{StaticResource AppTextBoxStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
					<TextBlock Margin="0,12,0,4" Text="Description" Style="{StaticResource FormLabelStyle}" />
					<TextBox MinHeight="80" AcceptsReturn="True" Style="{StaticResource MultilineTextBoxStyle}" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
					<StackPanel Margin="0,16,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
						<Button Command="{Binding NewCommand}" Content="New" Style="{StaticResource SecondaryButtonStyle}" />
						<Button Margin="{StaticResource Button.Margin}" Command="{Binding ToggleActiveCommand}" Content="{Binding ActionText}" Style="{StaticResource SecondaryButtonStyle}" />
						<Button Margin="{StaticResource Button.Margin}" Command="{Binding SaveCommand}" Content="Save" Style="{StaticResource PrimaryButtonStyle}" />
					</StackPanel>
				</StackPanel>
			</controls:Card>
		</Grid>
	</Grid>
</UserControl>
