<UserControl
	x:Class="Depot.Views.ItemsView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<Grid>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="16" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="16" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<controls:PageHeader Grid.Row="0" Title="Items">
			<controls:PageHeader.Actions>
				<Button
					Content="New Item"
					Style="{StaticResource PrimaryButtonStyle}"
					Command="{Binding NewItemCommand}" />
			</controls:PageHeader.Actions>
		</controls:PageHeader>

		<controls:SearchBox
			Grid.Row="2"
			Placeholder="Search items"
			Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
			ToolTip="Search by part number, description, manufacturer or category" />

		<Grid Grid.Row="4">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*" />
				<ColumnDefinition Width="24" />
				<ColumnDefinition Width="1*" />
			</Grid.ColumnDefinitions>

			<DataGrid
				Grid.Column="0"
				Style="{StaticResource AppDataGridStyle}"
				ItemsSource="{Binding Items}"
				SelectedItem="{Binding SelectedItem}"
				AutoGenerateColumns="False"
				IsReadOnly="True"
				CanUserAddRows="False"
				CanUserDeleteRows="False"
				HeadersVisibility="Column"
				RowHeaderWidth="0">

				<DataGrid.Columns>

					<DataGridTextColumn
						Header="Part Number"
						Binding="{Binding PartNumber}"
						Width="220" />

					<DataGridTextColumn
						Header="Description"
						Binding="{Binding Description}"
						Width="*" />

					<DataGridTextColumn
						Header="Manufacturer"
						Binding="{Binding Manufacturer}"
						Width="180" />

					<DataGridTextColumn
						Header="Category"
						Binding="{Binding Category}"
						Width="180" />

				</DataGrid.Columns>

			</DataGrid>

			<Border
				Grid.Column="2"
				Padding="16"
				BorderBrush="#DDDDDD"
				BorderThickness="1">

				<Grid>

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<TextBlock
						Grid.Row="0"
						Text="{Binding Editor.EditorTitle}"
						Style="{StaticResource SectionTitleStyle}" />

					<Border
						Grid.Row="2"
						Padding="8"
						Background="#FFF3F3"
						BorderBrush="#CC5555"
						BorderThickness="1"
						Visibility="{Binding HasErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}">

						<TextBlock
							Text="{Binding ErrorMessage}"
							TextWrapping="Wrap" />

					</Border>

					<StackPanel Grid.Row="4">
						<TextBlock Text="Part Number" />
						<TextBox
							Style="{StaticResource AppTextBoxStyle}"
							IsEnabled="{Binding Editor.CanEditPartNumber}"
							Text="{Binding Editor.PartNumber, UpdateSourceTrigger=PropertyChanged}" />
					</StackPanel>

					<StackPanel Grid.Row="6">
						<TextBlock Text="Description" />
						<TextBox
							Style="{StaticResource AppTextBoxStyle}"
							Text="{Binding Editor.Description, UpdateSourceTrigger=PropertyChanged}" />
					</StackPanel>

					<StackPanel Grid.Row="8">
						<TextBlock Text="Manufacturer" />
						<TextBox
							Style="{StaticResource AppTextBoxStyle}"
							Text="{Binding Editor.Manufacturer, UpdateSourceTrigger=PropertyChanged}" />
					</StackPanel>

					<StackPanel Grid.Row="10">
						<TextBlock Text="Category" />
						<TextBox
							Style="{StaticResource AppTextBoxStyle}"
							Text="{Binding Editor.Category, UpdateSourceTrigger=PropertyChanged}" />
					</StackPanel>

					<StackPanel
						Grid.Row="12"
						Orientation="Horizontal"
						HorizontalAlignment="Right">

						<Button
							Content="Deactivate"
							Style="{StaticResource DangerButtonStyle}"
							Command="{Binding DeactivateItemCommand}" />

						<Button
							Content="{Binding Editor.SaveButtonText}"
							Style="{StaticResource PrimaryButtonStyle}"
							Margin="{StaticResource Button.Margin}"
							Command="{Binding SaveItemCommand}" />

					</StackPanel>

				</Grid>

			</Border>

		</Grid>

	</Grid>

</UserControl>
