<UserControl
	x:Class="Depot.Views.MovementsView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<controls:PageHeader
			Grid.Row="0"
			Title="Movements"
			Subtitle="Record purchases, withdrawals, and corrections while reviewing stock activity." />

		<controls:SearchBox
			Grid.Row="1"
			Margin="{StaticResource Search.Margin}"
			Placeholder="Search movements"
			Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
			ToolTip="Search by part number, description, purpose, location, reference, or notes" />

		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="3*" />
				<ColumnDefinition Width="24" />
				<ColumnDefinition Width="2*" />
			</Grid.ColumnDefinitions>

			<controls:Card Grid.Column="0">
				<controls:Card.Header>
					<TextBlock Text="Movement History" Style="{StaticResource SectionTitleStyle}" />
				</controls:Card.Header>
				<Grid>
					<DataGrid
						ItemsSource="{Binding Items}"
						Style="{StaticResource AppDataGridStyle}"
						Visibility="{Binding HasItems, Converter={StaticResource BooleanToVisibilityConverter}}">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampLocal, StringFormat={}{0:g}}" Width="130" />
							<DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" Width="120" />
							<DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
							<DataGridTextColumn Header="Purpose" Binding="{Binding PurposeName}" Width="95" />
							<DataGridTextColumn Header="Location" Binding="{Binding LocationName}" Width="95" />
							<DataGridTextColumn Header="Type" Binding="{Binding MovementType}" Width="95" />
							<DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60" />
							<DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat={}{0:C2}}" Width="105" />
							<DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="120" />
						</DataGrid.Columns>
					</DataGrid>

					<controls:EmptyState
						Title="No movements found"
						Description="Adjust the search or create a new stock movement."
						Visibility="{Binding HasNoItems, Converter={StaticResource BooleanToVisibilityConverter}}" />
				</Grid>
			</controls:Card>

			<controls:Card Grid.Column="2">
				<controls:Card.Header>
					<TextBlock Text="New Movement" Style="{StaticResource SectionTitleStyle}" />
				</controls:Card.Header>

				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel>
						<Border
							Padding="12"
							Background="{StaticResource ErrorBrush}"
							CornerRadius="6"
							Visibility="{Binding HasErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
							<TextBlock
								Foreground="{StaticResource ErrorForegroundBrush}"
								Text="{Binding ErrorMessage}"
								TextWrapping="Wrap" />
						</Border>

						<TextBlock Margin="0,16,0,4" Text="Inventory" Style="{StaticResource FormLabelStyle}" />
						<ComboBox
							DisplayMemberPath="DisplayName"
							ItemsSource="{Binding AvailableInventories}"
							SelectedItem="{Binding SelectedInventory}"
							Style="{StaticResource AppComboBoxStyle}" />

						<TextBlock Margin="0,16,0,4" Text="Movement Type" Style="{StaticResource FormLabelStyle}" />
						<ComboBox
							ItemsSource="{Binding MovementTypes}"
							SelectedItem="{Binding Editor.MovementType}"
							Style="{StaticResource AppComboBoxStyle}" />

						<TextBlock Margin="0,16,0,4" Text="Quantity" Style="{StaticResource FormLabelStyle}" />
						<controls:TextInput Text="{Binding Editor.Quantity, UpdateSourceTrigger=PropertyChanged}" />

						<TextBlock Margin="0,16,0,4" Text="Unit Price" Style="{StaticResource FormLabelStyle}" />
						<controls:TextInput
							IsEnabled="{Binding Editor.RequiresUnitPrice}"
							Text="{Binding Editor.UnitPrice, UpdateSourceTrigger=PropertyChanged}" />

						<TextBlock Margin="0,16,0,4" Text="Reference" Style="{StaticResource FormLabelStyle}" />
						<controls:TextInput Text="{Binding Editor.Reference, UpdateSourceTrigger=PropertyChanged}" />

						<TextBlock Margin="0,16,0,4" Text="Notes" Style="{StaticResource FormLabelStyle}" />
						<TextBox
							Height="72"
							AcceptsReturn="True"
							Style="{StaticResource AppTextBoxStyle}"
							Text="{Binding Editor.Notes, UpdateSourceTrigger=PropertyChanged}"
							TextWrapping="Wrap" />

						<Button
							Margin="0,20,0,0"
							HorizontalAlignment="Right"
							Command="{Binding CreateMovementCommand}"
							Content="Create Movement"
							Style="{StaticResource PrimaryButtonStyle}" />
					</StackPanel>
				</ScrollViewer>
			</controls:Card>
		</Grid>
	</Grid>
</UserControl>
