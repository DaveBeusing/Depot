<UserControl
	x:Class="Depot.Views.MovementsView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="16" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<TextBlock
			Grid.Row="0"
			Text="Movements"
			FontSize="22"
			FontWeight="SemiBold" />

		<Grid Grid.Row="2">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*" />
				<ColumnDefinition Width="24" />
				<ColumnDefinition Width="1*" />
			</Grid.ColumnDefinitions>

			<DataGrid
				Grid.Column="0"
				ItemsSource="{Binding Items}"
				AutoGenerateColumns="False"
				IsReadOnly="True"
				CanUserAddRows="False"
				CanUserDeleteRows="False">

				<DataGrid.Columns>

					<DataGridTextColumn
						Header="Timestamp"
						Binding="{Binding TimestampLocal}"
						Width="180" />

					<DataGridTextColumn
						Header="Part Number"
						Binding="{Binding PartNumber}"
						Width="160" />

					<DataGridTextColumn
						Header="Description"
						Binding="{Binding Description}"
						Width="*" />

					<DataGridTextColumn
						Header="Type"
						Binding="{Binding MovementType}"
						Width="120" />

					<DataGridTextColumn
						Header="Quantity"
						Binding="{Binding Quantity}"
						Width="100" />

					<DataGridTextColumn
						Header="Unit Price"
						Binding="{Binding UnitPrice, StringFormat={}{0:N4}}"
						Width="120" />

					<DataGridTextColumn
						Header="Reference"
						Binding="{Binding Reference}"
						Width="160" />

				</DataGrid.Columns>

			</DataGrid>

			<Border
				Grid.Column="2"
				Padding="16"
				BorderBrush="#DDDDDD"
				BorderThickness="1">

				<Grid>

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<TextBlock
						Grid.Row="0"
						Text="New Movement"
						FontSize="18"
						FontWeight="SemiBold" />

					<Border
						Grid.Row="2"
						Padding="8"
						Background="#FFF3F3"
						BorderBrush="#CC5555"
						BorderThickness="1"
						Visibility="{Binding HasErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}">

						<TextBlock
							Text="{Binding ErrorMessage}"
							TextWrapping="Wrap" />

					</Border>

					<StackPanel Grid.Row="4">
						<TextBlock Text="Item" />
						<ComboBox
							Margin="0,4,0,0"
							ItemsSource="{Binding AvailableItems}"
							SelectedItem="{Binding SelectedItem}"
							DisplayMemberPath="DisplayName" />
					</StackPanel>

					<StackPanel Grid.Row="6">
						<TextBlock Text="Movement Type" />
						<ComboBox
							Margin="0,4,0,0"
							SelectedValue="{Binding Editor.MovementType}">
							<ComboBoxItem Content="Purchase" />
							<ComboBoxItem Content="Withdrawal" />
							<ComboBoxItem Content="Correction" />
						</ComboBox>
					</StackPanel>

					<StackPanel Grid.Row="8">
						<TextBlock Text="Quantity" />
						<TextBox
							Margin="0,4,0,0"
							Text="{Binding Editor.Quantity, UpdateSourceTrigger=PropertyChanged}" />
					</StackPanel>

					<StackPanel Grid.Row="10">
						<TextBlock Text="Unit Price" />
						<TextBox
							Margin="0,4,0,0"
							IsEnabled="{Binding Editor.RequiresUnitPrice}"
							Text="{Binding Editor.UnitPrice, UpdateSourceTrigger=PropertyChanged}" />
					</StackPanel>

					<StackPanel Grid.Row="12">
						<TextBlock Text="Reference" />
						<TextBox
							Margin="0,4,0,0"
							Text="{Binding Editor.Reference, UpdateSourceTrigger=PropertyChanged}" />
					</StackPanel>

					<StackPanel Grid.Row="14">
						<Button
							Width="120"
							Height="32"
							HorizontalAlignment="Right"
							Content="Create"
							Command="{Binding CreateMovementCommand}" />
					</StackPanel>

				</Grid>

			</Border>

		</Grid>

	</Grid>

</UserControl>