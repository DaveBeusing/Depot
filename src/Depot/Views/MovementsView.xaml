<UserControl
	x:Class="Depot.Views.MovementsView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="16" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<TextBlock
			Grid.Row="0"
			Text="Movements"
			FontSize="22"
			FontWeight="SemiBold" />

		<DataGrid
			Grid.Row="2"
			ItemsSource="{Binding Items}"
			AutoGenerateColumns="False"
			IsReadOnly="True"
			CanUserAddRows="False"
			CanUserDeleteRows="False">

			<DataGrid.Columns>

				<DataGridTextColumn
					Header="Timestamp"
					Binding="{Binding TimestampLocal}"
					Width="180" />

				<DataGridTextColumn
					Header="Part Number"
					Binding="{Binding PartNumber}"
					Width="160" />

				<DataGridTextColumn
					Header="Description"
					Binding="{Binding Description}"
					Width="*" />

				<DataGridTextColumn
					Header="Type"
					Binding="{Binding MovementType}"
					Width="120" />

				<DataGridTextColumn
					Header="Quantity"
					Binding="{Binding Quantity}"
					Width="100" />

				<DataGridTextColumn
					Header="Unit Price"
					Binding="{Binding UnitPrice, StringFormat={}{0:N4}}"
					Width="120" />

				<DataGridTextColumn
					Header="Reference"
					Binding="{Binding Reference}"
					Width="160" />

			</DataGrid.Columns>

		</DataGrid>

	</Grid>

</UserControl>