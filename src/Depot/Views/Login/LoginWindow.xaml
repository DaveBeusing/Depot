<Window
	x:Class="Depot.Views.Login.LoginWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls"
	Title="Sign in to Depot"
	Icon="/Resources/Images/Depot.ico"
	Style="{StaticResource AppDialogWindowStyle}"
	WindowStartupLocation="CenterScreen"
	ShowInTaskbar="true">

	<Border
		Padding="32"
		Background="{StaticResource BackgroundBrush}">
		<controls:Card Width="400">
			<StackPanel>
				<Image
					Width="72"
					Height="64"
					HorizontalAlignment="Left"
					Margin="0,0,0,20"
					Source="/Resources/Images/Depot.png" />

				<TextBlock
					Text="Sign in to Depot"
					Style="{StaticResource PageTitleStyle}" />

				<TextBlock
					Margin="0,6,0,24"
					Foreground="{StaticResource SecondaryTextBrush}"
					Text="Use your Depot account to continue." />

				<TextBlock
					Text="Email"
					Style="{StaticResource FormLabelStyle}" />

				<TextBox
					Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
					Style="{StaticResource AppTextBoxStyle}" />

				<TextBlock
					Margin="0,16,0,4"
					Text="Password"
					Style="{StaticResource FormLabelStyle}" />

				<controls:PasswordInput
					PasswordValue="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

				<Border
					Margin="0,16,0,0"
					Padding="12"
					Background="{StaticResource ErrorBrush}"
					CornerRadius="6"
					Visibility="{Binding HasErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
					<TextBlock
						Foreground="{StaticResource ErrorForegroundBrush}"
						Text="{Binding ErrorMessage}"
						TextWrapping="Wrap" />
				</Border>

				<Button
					Margin="0,24,0,0"
					HorizontalAlignment="Stretch"
					Command="{Binding LoginCommand}"
					Content="Sign in"
					IsDefault="True"
					Style="{StaticResource PrimaryButtonStyle}" />

				<TextBlock
					Margin="0,20,0,0"
					HorizontalAlignment="Center"
					Style="{StaticResource CaptionStyle}"
					Text="Depot Inventory Management" />
			</StackPanel>
		</controls:Card>
	</Border>
</Window>
