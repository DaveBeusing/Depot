<UserControl
	x:Class="Depot.Views.InventoryView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="16" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="16" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<TextBlock
			Grid.Row="0"
			Text="Inventory"
			Style="{StaticResource PageTitleStyle}" />

		<TextBox
			Grid.Row="2"
			Style="{StaticResource SearchTextBoxStyle}"
			Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
			ToolTip="Search by part number, description, manufacturer, category, purpose or location" />

		<Grid Grid.Row="4">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*" />
				<ColumnDefinition Width="24" />
				<ColumnDefinition Width="1*" />
			</Grid.ColumnDefinitions>

			<DataGrid
				Grid.Column="0"
				Style="{StaticResource AppDataGridStyle}"
				ItemsSource="{Binding Items}"
				SelectedItem="{Binding SelectedItem}"
				AutoGenerateColumns="False"
				IsReadOnly="True"
				CanUserAddRows="False"
				CanUserDeleteRows="False"
				HeadersVisibility="Column"
				RowHeaderWidth="0">

				<DataGrid.Columns>

					<DataGridTextColumn
						Header="Part Number"
						Binding="{Binding PartNumber}"
						Width="220" />

					<DataGridTextColumn
						Header="Description"
						Binding="{Binding Description}"
						Width="*" />

					<DataGridTextColumn
						Header="Purpose"
						Binding="{Binding PurposeName}"
						Width="140" />

					<DataGridTextColumn
						Header="Location"
						Binding="{Binding LocationName}"
						Width="140" />

					<DataGridTextColumn
						Header="Stock"
						Binding="{Binding CurrentStock}"
						Width="100" />

					<DataGridTextColumn
						Header="Avg Cost"
						Binding="{Binding AverageCost, StringFormat={}{0:N2} EUR}"
						Width="140" />

					<DataGridTextColumn
						Header="Value"
						Binding="{Binding InventoryValue, StringFormat={}{0:N2} EUR}"
						Width="140" />

				</DataGrid.Columns>

			</DataGrid>

			<Border
				Grid.Column="2"
				Padding="20"
				Background="White"
				BorderBrush="#E5E7EB"
				BorderThickness="1">

				<Grid>

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="8" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<TextBlock
						Grid.Row="0"
						Text="Inventory Details"
						Style="{StaticResource SectionTitleStyle}" />

					<Border
						Grid.Row="2"
						Padding="16"
						Background="#F9FAFB"
						BorderBrush="#E5E7EB"
						BorderThickness="1">

						<Grid>

							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>

							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="8" />
								<RowDefinition Height="Auto" />
								<RowDefinition Height="8" />
								<RowDefinition Height="Auto" />
								<RowDefinition Height="8" />
								<RowDefinition Height="Auto" />
								<RowDefinition Height="8" />
								<RowDefinition Height="Auto" />
								<RowDefinition Height="8" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>

							<TextBlock
								Grid.Row="0"
								Grid.Column="0"
								Text="Part Number"
								Foreground="#6B7280" />

							<TextBlock
								Grid.Row="0"
								Grid.Column="1"
								Text="{Binding Details.PartNumber}"
								FontWeight="SemiBold" />

							<TextBlock
								Grid.Row="2"
								Grid.Column="0"
								Text="Description"
								Foreground="#6B7280" />

							<TextBlock
								Grid.Row="2"
								Grid.Column="1"
								Text="{Binding Details.Description}"
								TextWrapping="Wrap" />

							<TextBlock
								Grid.Row="4"
								Grid.Column="0"
								Text="Purpose"
								Foreground="#6B7280" />

							<TextBlock
								Grid.Row="4"
								Grid.Column="1"
								Text="{Binding Details.PurposeName}" />

							<TextBlock
								Grid.Row="6"
								Grid.Column="0"
								Text="Location"
								Foreground="#6B7280" />

							<TextBlock
								Grid.Row="6"
								Grid.Column="1"
								Text="{Binding Details.LocationName}" />

							<TextBlock
								Grid.Row="8"
								Grid.Column="0"
								Text="Manufacturer"
								Foreground="#6B7280" />

							<TextBlock
								Grid.Row="8"
								Grid.Column="1"
								Text="{Binding Details.Manufacturer}" />

							<TextBlock
								Grid.Row="10"
								Grid.Column="0"
								Text="Category"
								Foreground="#6B7280" />

							<TextBlock
								Grid.Row="10"
								Grid.Column="1"
								Text="{Binding Details.Category}" />

						</Grid>

					</Border>

					<Grid Grid.Row="4">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="12" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="12" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<Border
							Grid.Column="0"
							Padding="14"
							Background="#EFF6FF"
							BorderBrush="#DBEAFE"
							BorderThickness="1">

							<StackPanel>

								<TextBlock
									Text="Current Stock"
									Foreground="#6B7280"
									FontSize="12" />

								<TextBlock
									Margin="0,6,0,0"
									Text="{Binding Details.CurrentStock}"
									FontSize="22"
									FontWeight="SemiBold" />

							</StackPanel>

						</Border>

						<Border
							Grid.Column="2"
							Padding="14"
							Background="#F9FAFB"
							BorderBrush="#E5E7EB"
							BorderThickness="1">

							<StackPanel>

								<TextBlock
									Text="Average Cost"
									Foreground="#6B7280"
									FontSize="12" />

								<TextBlock
									Margin="0,6,0,0"
									Text="{Binding Details.AverageCost, StringFormat={}{0:N2} EUR}"
									FontSize="18"
									FontWeight="SemiBold" />

							</StackPanel>

						</Border>

						<Border
							Grid.Column="4"
							Padding="14"
							Background="#F0FDF4"
							BorderBrush="#DCFCE7"
							BorderThickness="1">

							<StackPanel>

								<TextBlock
									Text="Inventory Value"
									Foreground="#6B7280"
									FontSize="12" />

								<TextBlock
									Margin="0,6,0,0"
									Text="{Binding Details.InventoryValue, StringFormat={}{0:N2} EUR}"
									FontSize="18"
									FontWeight="SemiBold" />

							</StackPanel>

						</Border>

					</Grid>

					<TextBlock
						Grid.Row="6"
						Text="Recent Movements"
						Style="{StaticResource SectionTitleStyle}" />

					<DataGrid
						Grid.Row="8"
						Style="{StaticResource AppDataGridStyle}"
						ItemsSource="{Binding Details.RecentMovements}"
						AutoGenerateColumns="False"
						IsReadOnly="True"
						CanUserAddRows="False"
						CanUserDeleteRows="False"
						HeadersVisibility="Column"
						RowHeaderWidth="0">

						<DataGrid.Columns>

							<DataGridTextColumn
								Header="Date"
								Binding="{Binding TimestampLocal}"
								Width="140" />

							<DataGridTextColumn
								Header="Type"
								Binding="{Binding MovementType}"
								Width="100" />

							<DataGridTextColumn
								Header="Qty"
								Binding="{Binding Quantity}"
								Width="70" />

						</DataGrid.Columns>

					</DataGrid>

				</Grid>

			</Border>

		</Grid>

	</Grid>

</UserControl>
