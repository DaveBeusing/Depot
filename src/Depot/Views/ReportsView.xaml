<UserControl
	x:Class="Depot.Views.ReportsView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="16" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="16" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="16" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Grid Grid.Row="0">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<TextBlock
				Grid.Column="0"
				Text="Reports"
				Style="{StaticResource PageTitleStyle}" />

			<TextBlock
				Grid.Column="1"
				MaxWidth="520"
				VerticalAlignment="Center"
				Text="{Binding ExportStatusText}"
				TextTrimming="CharacterEllipsis"
				ToolTip="{Binding ExportStatusText}"
				Visibility="{Binding HasExportStatus, Converter={StaticResource BooleanToVisibilityConverter}}">

				<TextBlock.Style>
					<Style TargetType="TextBlock">
						<Setter Property="Foreground" Value="#6B7280" />
						<Style.Triggers>
							<DataTrigger Binding="{Binding IsExportStatusError}" Value="True">
								<Setter Property="Foreground" Value="#B91C1C" />
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</TextBlock.Style>

			</TextBlock>

			<Button
				Grid.Column="3"
				Content="Export"
				Style="{StaticResource PrimaryButtonStyle}"
				Command="{Binding ExportCommand}" />

		</Grid>

		<Grid Grid.Row="2">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="220" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<ComboBox
				Grid.Column="0"
				Height="32"
				Style="{StaticResource AppComboBoxStyle}"
				ItemsSource="{Binding ReportOptions}"
				SelectedItem="{Binding SelectedReport, Mode=TwoWay}"
				ToolTip="Select report" />

			<TextBox
				Grid.Column="2"
				Height="32"
				Style="{StaticResource SearchTextBoxStyle}"
				Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
				ToolTip="{Binding SearchToolTip}" />

		</Grid>

		<Grid Grid.Row="4">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Border
				Grid.Column="0"
				Padding="20"
				Background="#F9FAFB"
				BorderBrush="#E5E7EB"
				BorderThickness="1">

				<StackPanel
					HorizontalAlignment="Center"
					VerticalAlignment="Center">

					<TextBlock
						Text="Inventory Rows"
						Foreground="#6B7280"
						TextAlignment="Center"
						HorizontalAlignment="Center" />

					<TextBlock
						Margin="0,8,0,0"
						Text="{Binding TotalInventoryRows}"
						FontSize="32"
						FontWeight="SemiBold"
						TextAlignment="Center"
						HorizontalAlignment="Center" />

				</StackPanel>

			</Border>

			<Border
				Grid.Column="2"
				Padding="20"
				Background="#F9FAFB"
				BorderBrush="#E5E7EB"
				BorderThickness="1">

				<StackPanel
					HorizontalAlignment="Center"
					VerticalAlignment="Center">

					<TextBlock
						Text="Items"
						Foreground="#6B7280"
						TextAlignment="Center"
						HorizontalAlignment="Center" />

					<TextBlock
						Margin="0,8,0,0"
						Text="{Binding TotalItems}"
						FontSize="32"
						FontWeight="SemiBold"
						TextAlignment="Center"
						HorizontalAlignment="Center" />

				</StackPanel>

			</Border>

			<Border
				Grid.Column="4"
				Padding="20"
				Background="#F9FAFB"
				BorderBrush="#E5E7EB"
				BorderThickness="1">

				<StackPanel
					HorizontalAlignment="Center"
					VerticalAlignment="Center">

					<TextBlock
						Text="Total Stock"
						Foreground="#6B7280"
						TextAlignment="Center"
						HorizontalAlignment="Center" />

					<TextBlock
						Margin="0,8,0,0"
						Text="{Binding TotalStockQuantity}"
						FontSize="32"
						FontWeight="SemiBold"
						TextAlignment="Center"
						HorizontalAlignment="Center" />

				</StackPanel>

			</Border>

			<Border
				Grid.Column="6"
				Padding="20"
				Background="#F9FAFB"
				BorderBrush="#E5E7EB"
				BorderThickness="1">

				<StackPanel
					HorizontalAlignment="Center"
					VerticalAlignment="Center">

					<TextBlock
						Text="Inventory Value"
						Foreground="#6B7280"
						TextAlignment="Center"
						HorizontalAlignment="Center" />

					<TextBlock
						Margin="0,8,0,0"
						Text="{Binding TotalInventoryValue, StringFormat={}{0:N2} EUR}"
						FontSize="32"
						FontWeight="SemiBold"
						TextAlignment="Center"
						HorizontalAlignment="Center" />

				</StackPanel>

			</Border>

		</Grid>

		<Border
			Grid.Row="6"
			Padding="16"
			Background="White"
			BorderBrush="#E5E7EB"
			BorderThickness="1">

			<Grid>

				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="16" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<TextBlock
					Grid.Row="0"
					Text="{Binding ReportTitle}"
					Style="{StaticResource SectionTitleStyle}" />

				<DataGrid
					Grid.Row="2"
					ItemsSource="{Binding InventoryValueItems}"
					AutoGenerateColumns="False"
					IsReadOnly="True"
					CanUserAddRows="False"
					CanUserDeleteRows="False"
					HeadersVisibility="Column"
					RowHeaderWidth="0"
					Visibility="{Binding ShowInventoryValueRows, Converter={StaticResource BooleanToVisibilityConverter}}">

					<DataGrid.Columns>

						<DataGridTextColumn
							Header="Part Number"
							Binding="{Binding PartNumber}"
							Width="180" />

						<DataGridTextColumn
							Header="Description"
							Binding="{Binding Description}"
							Width="*" />

						<DataGridTextColumn
							Header="Purpose"
							Binding="{Binding PurposeName}"
							Width="140" />

						<DataGridTextColumn
							Header="Location"
							Binding="{Binding LocationName}"
							Width="140" />

						<DataGridTextColumn
							Header="Stock"
							Binding="{Binding CurrentStock}"
							Width="100" />

						<DataGridTextColumn
							Header="Avg Cost"
							Binding="{Binding AverageCost, StringFormat={}{0:N4} EUR}"
							Width="140" />

						<DataGridTextColumn
							Header="Value"
							Binding="{Binding InventoryValue, StringFormat={}{0:N2} EUR}"
							Width="140" />

					</DataGrid.Columns>

				</DataGrid>

				<DataGrid
					Grid.Row="2"
					ItemsSource="{Binding GroupedItems}"
					AutoGenerateColumns="False"
					IsReadOnly="True"
					CanUserAddRows="False"
					CanUserDeleteRows="False"
					HeadersVisibility="Column"
					RowHeaderWidth="0"
					Visibility="{Binding ShowGroupedRows, Converter={StaticResource BooleanToVisibilityConverter}}">

					<DataGrid.Columns>

						<DataGridTextColumn
							Header="Group"
							Binding="{Binding GroupName}"
							Width="*" />

						<DataGridTextColumn
							Header="Inventory Rows"
							Binding="{Binding InventoryRows}"
							Width="140" />

						<DataGridTextColumn
							Header="Items"
							Binding="{Binding TotalItems}"
							Width="100" />

						<DataGridTextColumn
							Header="Total Stock"
							Binding="{Binding TotalStockQuantity}"
							Width="120" />

						<DataGridTextColumn
							Header="Inventory Value"
							Binding="{Binding InventoryValue, StringFormat={}{0:N2} EUR}"
							Width="160" />

					</DataGrid.Columns>

				</DataGrid>

				<TextBlock
					Grid.Row="2"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Foreground="#6B7280"
					Text="{Binding EmptyReportMessage}"
					TextAlignment="Center"
					Visibility="{Binding HasNoReportRows, Converter={StaticResource BooleanToVisibilityConverter}}" />

			</Grid>

		</Border>

	</Grid>

</UserControl>
