<UserControl
	x:Class="Depot.Views.ReportsView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="24" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<controls:PageHeader
			Grid.Row="0"
			Title="Reports"
			Subtitle="Analyze inventory value and stock distribution, then export the current result.">
			<controls:PageHeader.Actions>
				<StackPanel Orientation="Horizontal">
					<TextBlock
						MaxWidth="420"
						Margin="0,0,16,0"
						VerticalAlignment="Center"
						Foreground="{StaticResource SuccessForegroundBrush}"
						Text="{Binding ExportStatusText}"
						TextTrimming="CharacterEllipsis"
						ToolTip="{Binding ExportStatusText}"
						Visibility="{Binding HasExportSuccessStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
					<TextBlock
						MaxWidth="420"
						Margin="0,0,16,0"
						VerticalAlignment="Center"
						Foreground="{StaticResource ErrorForegroundBrush}"
						Text="{Binding ExportStatusText}"
						TextTrimming="CharacterEllipsis"
						ToolTip="{Binding ExportStatusText}"
						Visibility="{Binding HasExportErrorStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
					<Button
						Command="{Binding ExportCommand}"
						Content="Export"
						Style="{StaticResource PrimaryButtonStyle}" />
				</StackPanel>
			</controls:PageHeader.Actions>
		</controls:PageHeader>

		<Grid Grid.Row="1" Margin="{StaticResource Search.Margin}">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="240" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<ComboBox
				Grid.Column="0"
				Height="36"
				ItemsSource="{Binding ReportOptions}"
				SelectedItem="{Binding SelectedReport, Mode=TwoWay}"
				Style="{StaticResource AppComboBoxStyle}"
				ToolTip="Select report" />

			<controls:SearchBox
				Grid.Column="2"
				Placeholder="Search report"
				Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
				ToolTip="{Binding SearchToolTip}" />
		</Grid>

		<controls:OperationStatus
			Grid.Row="2"
			Margin="0,0,0,16"
			ErrorText="{Binding OperationError}"
			HasError="{Binding HasOperationError}"
			IsBusy="{Binding IsBusy}"
			StatusText="{Binding StatusText}" />

		<Grid Grid.Row="3">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<controls:MetricCard
				Grid.Column="0"
				Icon="M 3,3 L 17,3 L 17,17 L 3,17 Z M 3,8 L 17,8 M 8,3 L 8,17"
				SupportingText="Rows in the current result"
				Title="Inventory Rows"
				Value="{Binding TotalInventoryRows}" />

			<controls:MetricCard
				Grid.Column="2"
				Icon="M 5,3 L 15,3 L 17,5 L 17,18 L 3,18 L 3,5 Z M 7,8 L 13,8 M 7,12 L 13,12"
				SupportingText="Distinct catalog items"
				Title="Items"
				Value="{Binding TotalItems}" />

			<controls:MetricCard
				Grid.Column="4"
				Icon="M 2,6 L 10,2 L 18,6 L 10,10 Z M 2,6 L 2,14 L 10,18 L 10,10 M 18,6 L 18,14 L 10,18"
				SupportingText="Units represented"
				Title="Total Stock"
				Value="{Binding TotalStockQuantity}" />

			<controls:MetricCard
				Grid.Column="6"
				Icon="M 18,10 A 8,8 0 1 1 2,10 A 8,8 0 1 1 18,10 M 12.5,6.5 C 11.8,5.8 8.5,5.5 8,7 C 7.4,8.8 12.8,8.5 12,11 C 11.5,12.5 8.2,12.2 7.5,11.5 M 10,4.5 L 10,15.5"
				SupportingText="Current inventory valuation"
				Title="Inventory Value"
				Value="{Binding TotalInventoryValue}"
				ValueStringFormat="{}{0:C2}" />
		</Grid>

		<controls:Card Grid.Row="5">
			<controls:Card.Header>
				<TextBlock Text="{Binding ReportTitle}" Style="{StaticResource SectionTitleStyle}" />
			</controls:Card.Header>

			<Grid>
				<DataGrid
					ItemsSource="{Binding InventoryValueItems}"
					Style="{StaticResource AppDataGridStyle}"
					Visibility="{Binding ShowInventoryValueRows, Converter={StaticResource BooleanToVisibilityConverter}}">
					<DataGrid.Columns>
						<DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" Width="150" />
						<DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
						<DataGridTextColumn Header="Purpose" Binding="{Binding PurposeName}" Width="120" />
						<DataGridTextColumn Header="Location" Binding="{Binding LocationName}" Width="120" />
						<DataGridTextColumn Header="Stock" Binding="{Binding CurrentStock}" Width="80" />
						<DataGridTextColumn Header="Avg Cost" Binding="{Binding AverageCost, StringFormat={}{0:C2}}" Width="120" />
						<DataGridTextColumn Header="Value" Binding="{Binding InventoryValue, StringFormat={}{0:C2}}" Width="120" />
					</DataGrid.Columns>
				</DataGrid>

				<DataGrid
					ItemsSource="{Binding GroupedItems}"
					Style="{StaticResource AppDataGridStyle}"
					Visibility="{Binding ShowGroupedRows, Converter={StaticResource BooleanToVisibilityConverter}}">
					<DataGrid.Columns>
						<DataGridTextColumn Header="Group" Binding="{Binding GroupName}" Width="*" />
						<DataGridTextColumn Header="Inventory Rows" Binding="{Binding InventoryRows}" Width="140" />
						<DataGridTextColumn Header="Items" Binding="{Binding TotalItems}" Width="100" />
						<DataGridTextColumn Header="Total Stock" Binding="{Binding TotalStockQuantity}" Width="120" />
						<DataGridTextColumn Header="Inventory Value" Binding="{Binding InventoryValue, StringFormat={}{0:C2}}" Width="160" />
					</DataGrid.Columns>
				</DataGrid>

				<controls:EmptyState
					Title="No report data"
					Description="{Binding EmptyReportMessage}"
					Visibility="{Binding HasNoReportRows, Converter={StaticResource BooleanToVisibilityConverter}}" />
			</Grid>
		</controls:Card>
	</Grid>
</UserControl>
