<UserControl
	x:Class="Depot.Views.Shared.PlaceholderView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<controls:Card>
		<controls:EmptyState
			Title="{Binding Title}"
			Description="{Binding Description}" />
	</controls:Card>

</UserControl>
