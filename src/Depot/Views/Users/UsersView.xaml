<UserControl
	x:Class="Depot.Views.Users.UsersView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<controls:PageHeader
			Grid.Row="0"
			Title="Users">
			<controls:PageHeader.Actions>
				<controls:OperationStatus
					ErrorText="{Binding OperationError}"
					HasError="{Binding HasOperationError}"
					IsBusy="{Binding IsBusy}"
					StatusText="{Binding StatusText}" />
			</controls:PageHeader.Actions>
		</controls:PageHeader>

		<controls:SearchBox
			Grid.Row="1"
			Margin="{StaticResource Search.Margin}"
			Placeholder="Search users by name or email"
			Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

		<Border
			Grid.Row="2"
			Margin="0,0,0,16"
			Padding="12"
			Background="{StaticResource ErrorBrush}"
			CornerRadius="6"
			Visibility="{Binding HasErrorMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
			<TextBlock
				Foreground="{StaticResource ErrorForegroundBrush}"
				Text="{Binding ErrorMessage}"
				TextWrapping="Wrap" />
		</Border>

		<Grid Grid.Row="3">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="320" />
				<ColumnDefinition Width="16" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Grid Grid.Column="0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="8" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
					<Button Command="{Binding PreviousPageCommand}" Content="Previous" Style="{StaticResource SecondaryButtonStyle}" />
					<TextBlock Margin="12,0" VerticalAlignment="Center" Text="{Binding PageNumber, StringFormat=Page {0}}" />
					<Button Command="{Binding NextPageCommand}" Content="Next" Style="{StaticResource SecondaryButtonStyle}" />
				</StackPanel>
				<ListBox
				Grid.Row="2"
				ItemsSource="{Binding Users}"
				SelectedItem="{Binding SelectedUser}"
				Style="{StaticResource AppListBoxStyle}">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<Grid Margin="0,6">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>
							<TextBlock
								FontWeight="SemiBold"
								Text="{Binding DisplayName}" />
							<TextBlock
								Grid.Row="1"
								Margin="0,2,0,0"
								Foreground="{StaticResource SecondaryTextBrush}"
								Text="{Binding Email}"
								TextTrimming="CharacterEllipsis" />
						</Grid>
					</DataTemplate>
				</ListBox.ItemTemplate>
				</ListBox>
			</Grid>

			<controls:Card Grid.Column="2">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="4" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="4" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="4" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="4" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="16" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="12" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<TextBlock
						Grid.Row="0"
						Text="{Binding Editor.EditorTitle}"
						Style="{StaticResource SectionTitleStyle}" />

					<TextBlock Grid.Row="2" Text="Email" Style="{StaticResource FormLabelStyle}" />
					<TextBox
						Grid.Row="4"
						Style="{StaticResource AppTextBoxStyle}"
						Text="{Binding Editor.Email}" />

					<TextBlock Grid.Row="6" Text="Display name" Style="{StaticResource FormLabelStyle}" />
					<TextBox
						Grid.Row="8"
						Style="{StaticResource AppTextBoxStyle}"
						Text="{Binding Editor.DisplayName}" />

					<TextBlock Grid.Row="10" Text="Password" Style="{StaticResource FormLabelStyle}" />
					<controls:PasswordInput
						Grid.Row="12"
						PasswordValue="{Binding Editor.Password, UpdateSourceTrigger=PropertyChanged}" />
					<TextBlock
						Grid.Row="14"
						Style="{StaticResource HintStyle}"
						Text="{Binding Editor.PasswordHint}" />

					<CheckBox
						Grid.Row="16"
						Content="Administrator"
						IsChecked="{Binding Editor.IsAdministrator}"
						Style="{StaticResource AppCheckBoxStyle}" />

					<Grid Grid.Row="18">
						<controls:StatusBadge
							Content="Active"
							Variant="Success"
							Visibility="{Binding Editor.IsActive, Converter={StaticResource BooleanToVisibilityConverter}}" />
						<controls:StatusBadge
							Content="Inactive"
							Variant="Neutral"
							Visibility="{Binding Editor.IsInactive, Converter={StaticResource BooleanToVisibilityConverter}}" />
					</Grid>

					<StackPanel
						Grid.Row="20"
						HorizontalAlignment="Right"
						Orientation="Horizontal">
						<Button
							Command="{Binding NewUserCommand}"
							Content="New"
							Style="{StaticResource PrimaryButtonStyle}" />
						<Button
							Margin="{StaticResource Button.Margin}"
							Command="{Binding SaveUserCommand}"
							Content="Save"
							Style="{StaticResource PrimaryButtonStyle}" />
						<Button
							Margin="{StaticResource Button.Margin}"
							Command="{Binding ToggleActiveCommand}"
							Content="{Binding Editor.ActivationButtonText}"
							Style="{StaticResource DangerButtonStyle}" />
					</StackPanel>
				</Grid>
			</controls:Card>
		</Grid>
	</Grid>
</UserControl>
