<UserControl
	x:Class="Depot.Views.Users.UsersView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Depot.Controls">

	<Grid>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="16"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="8"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock
			Grid.Row="0"
			Text="Users"
			Style="{StaticResource PageTitleStyle}" />

		<controls:SearchBox
			Grid.Row="2"
			Margin="{StaticResource Search.Margin}"
			Placeholder="Search users"
			Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

		<Grid Grid.Row="4">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="320"/>
				<ColumnDefinition Width="16"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- User List -->
			<ListBox
				Grid.Column="0"
				Style="{StaticResource AppListBoxStyle}"
				ItemsSource="{Binding Users}"
				SelectedItem="{Binding SelectedUser}"
				BorderThickness="1"
				BorderBrush="{StaticResource BorderBrush}">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<Border Padding="12">
							<StackPanel>
								<TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
								<TextBlock Margin="0,2,0,0" Text="{Binding Role}" Foreground="{StaticResource SecondaryTextBrush}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>

			<!-- Editor -->
			<Border
				Grid.Column="2"
				Style="{StaticResource CardStyle}">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="16"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="4"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="12"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="4"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="12"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="12"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>
					<TextBlock
						Grid.Row="0"
						Text="{Binding Editor.EditorTitle}"
						Style="{StaticResource SectionTitleStyle}" />

					<TextBlock Grid.Row="2" Text="User name" Style="{StaticResource FormLabelStyle}" />
					<TextBox Grid.Row="4"
						Text="{Binding Editor.UserName}"
						Style="{StaticResource AppTextBoxStyle}"
						IsReadOnly="{Binding Editor.IsExistingUser}" />

					<TextBlock Grid.Row="6" Text="Display name" Style="{StaticResource FormLabelStyle}"/>
					<TextBox Grid.Row="8"
						Style="{StaticResource AppTextBoxStyle}"
						Text="{Binding Editor.DisplayName}" />

					<CheckBox
						Grid.Row="10"
						Content="Administrator"
						Style="{StaticResource AppCheckBoxStyle}"
						IsChecked="{Binding Editor.IsAdministrator}" />

					<StackPanel Grid.Row="12">
						<Grid>
							<Border
								Style="{StaticResource ActiveStatusBadgeStyle}"
								Visibility="{Binding Editor.IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">

								<TextBlock
									Text="Active"
									Style="{StaticResource StatusBadgeTextStyle}" />

							</Border>

							<Border
								Style="{StaticResource InactiveStatusBadgeStyle}"
								Visibility="{Binding Editor.IsInactive, Converter={StaticResource BooleanToVisibilityConverter}}">

								<TextBlock
									Text="Inactive"
									Style="{StaticResource StatusBadgeTextStyle}" />

							</Border>
						</Grid>
					</StackPanel>



					<StackPanel
						Grid.Row="14"
						Orientation="Horizontal"
						HorizontalAlignment="Right">

						<Button
							Content="New"
							Command="{Binding NewUserCommand}"
							Style="{StaticResource PrimaryButtonStyle}" />

						<Button
							Content="Save"
							Command="{Binding SaveUserCommand}"
							Margin="{StaticResource Button.Margin}"
							Style="{StaticResource PrimaryButtonStyle}" />

						<Button
							Content="{Binding Editor.ActivationButtonText}"
							Command="{Binding ToggleActiveCommand}"
							Margin="{StaticResource Button.Margin}"
							Style="{StaticResource DangerButtonStyle}" />

					</StackPanel>

				</Grid>

			</Border>

		</Grid>

	</Grid>

</UserControl>
